# Copy this file to .env.local and fill in real values.
# Do not commit real API keys.

# Public browser config
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_ENV=sandbox
VITE_GA4_MEASUREMENT_ID=

# Server-only Supabase config
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Management API config for applying Auth email templates
# Create the access token in Supabase Dashboard > Account > Access Tokens.
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# PayPal server config
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_WEBHOOK_ID=

# Printful server config
PRINTFUL_API_TOKEN=
PRINTFUL_STORE_ID=

# Resend server config
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SUPPORT_EMAIL=

# Store config
SHOP_BRAND_NAME=Dreaming in 1989
SHOP_CURRENCY=USD
SHOP_COUNTRY=US
PUBLIC_SITE_URL=http://127.0.0.1:5173

# Cost guardrails
# Keep a paid-capable service disabled until its dashboard limit is configured.
COST_GUARD_MODE=strict
COST_ALERT_EMAIL=

POSTHOG_ENABLED=false
POSTHOG_COST_CAP_CONFIRMED=false

SENTRY_ENABLED=false
SENTRY_COST_CAP_CONFIRMED=false

CLOUDFLARE_R2_ENABLED=false
CLOUDFLARE_R2_COST_CAP_CONFIRMED=false

VERCEL_PRODUCTION_ENABLED=false
VERCEL_SPEND_LIMIT_CONFIRMED=false
